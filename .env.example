# Banco de dados PostgreSQL
# Se usar o docker-compose incluido, esta URL ja funciona:
DATABASE_URL="postgresql://sgc:sgc@localhost:5432/sgc?schema=public"

# NextAuth
# Gere um valor com: openssl rand -base64 32  (ou qualquer string longa e aleatoria)
NEXTAUTH_SECRET="troque-este-segredo-por-uma-string-longa-e-aleatoria"
NEXTAUTH_URL="http://localhost:3000"

# Numero de dias sem contato para marcar um lead como inativo
LEAD_INACTIVE_DAYS=7
